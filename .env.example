# ─── 前端 (apps/web) ───────────────────────────────────────────
# Workers API 基地址（本地默认 http://localhost:8787）
VITE_API_BASE_URL=http://localhost:8787

# Supabase（用户/管理员认证）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# 与注册邮箱一致时自动获得 admin 角色（可选）
VITE_ADMIN_EMAIL=1060707057@qq.com

# ─── Workers API (workers/api) — 仅服务端，切勿暴露到前端 ──────────
# GitHub 个人访问令牌（读写笔记仓库）
GITHUB_TOKEN=
# 目标仓库 owner/repo
GITHUB_REPO=your-name/webbook-data
# 默认分支
GITHUB_BRANCH=main

# DeepSeek（或兼容 OpenAI 的 AI Provider）
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# 联网检索（Workers 服务端）
RSS_FEEDS_DOMESTIC=https://www.ithome.com/rss/,https://www.solidot.org/index.rss,https://feeds.feedburner.com/sspai
RSS_FEEDS_INTERNATIONAL=https://hnrss.org/frontpage,http://feeds.bbci.co.uk/zhongwen/simp/rss.xml
DOMESTIC_NEWS_RATIO=0.7
# 国内博查 / 国际 Tavily（secret 注入，勿写进仓库）
SEARCH_PROVIDER_DOMESTIC=bocha
SEARCH_PROVIDER_INTERNATIONAL=tavily
SEARCH_API_KEY=
# SEARCH_API_KEY_INTERNATIONAL=

# Supabase service role（服务端校验会话/角色）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 与 VITE_ADMIN_EMAIL 相同；Worker 据此授予 /api/admin/* 权限（wrangler.toml 或 .dev.vars）
ADMIN_EMAIL=1060707057@qq.com

# 短信服务商（admin 手机验证，后续接入）
SMS_PROVIDER=
SMS_ACCESS_KEY=
SMS_SECRET=
